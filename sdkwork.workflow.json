{
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-membership",
    "name": "SDKWork Membership",
    "repository": "Sdkwork-Cloud/sdkwork-membership",
    "sourcePath": ".",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-membership",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "auto",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-app-topology",
      "repository": "Sdkwork-Cloud/sdkwork-app-topology",
      "ref": "main",
      "refInput": "SDKWORK_APP_TOPOLOGY_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "ref": "main",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-account",
      "repository": "Sdkwork-Cloud/sdkwork-account",
      "ref": "main",
      "refInput": "SDKWORK_ACCOUNT_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-core",
      "repository": "Sdkwork-Cloud/sdkwork-core",
      "ref": "main",
      "refInput": "SDKWORK_CORE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "ref": "main",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "ref": "main",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-utils",
      "repository": "Sdkwork-Cloud/sdkwork-utils",
      "ref": "main",
      "refInput": "SDKWORK_UTILS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-ui",
      "repository": "Sdkwork-Cloud/sdkwork-ui",
      "ref": "main",
      "refInput": "SDKWORK_UI_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-iam",
      "repository": "Sdkwork-Cloud/sdkwork-iam",
      "ref": "main",
      "refInput": "SDKWORK_IAM_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-commons",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-commons",
      "ref": "main",
      "refInput": "SDKWORK_SDK_COMMONS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "ref": "main",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --no-frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Run SDKWork Membership verification",
        "shell": "pwsh",
        "run": "pnpm verify"
      }
    ],
    "package": [
      {
        "name": "Build release binary",
        "shell": "pwsh",
        "run": "cargo build --release -p sdkwork-api-membership-standalone-gateway --bin sdkwork-api-membership-standalone-gateway"
      }
    ],
    "validate": [
      {
        "name": "Validate repository structure",
        "shell": "pwsh",
        "run": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
      },
      {
        "name": "Validate database framework standard",
        "shell": "pwsh",
        "run": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root ."
      },
      {
        "name": "Validate API response envelope",
        "shell": "pwsh",
        "run": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-standalone-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["target/release/sdkwork-api-membership-standalone-gateway"],
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    }
  ],
  "security": {
    "artifactAttestations": true,
    "sbomRequired": false,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
