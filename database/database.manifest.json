{
  "schemaVersion": 1,
  "kind": "sdkwork.database.module",
  "moduleId": "membership",
  "serviceCode": "MEMBERSHIP",
  "displayName": "Membership Database",
  "owner": "sdkwork-membership",
  "engines": ["postgres", "sqlite"],
  "defaultEngine": "postgres",
  "tablePrefix": "commerce_",
  "contractVersion": "1.1.0",
  "baselineStrategy": "baseline-plus-migrations",
  "modules": ["membership_extension"],
  "lifecycle": {
    "autoMigrate": true,
    "seedOnBoot": false,
    "defaultSeedLocale": "zh-CN",
    "defaultSeedProfile": "standard",
    "supportedSeedLocales": [
      "zh-CN",
      "en-US",
      "ja-JP",
      "de-DE",
      "fr-FR",
      "ru-RU",
      "ko-KR"
    ],
    "activeSeedLocales": ["zh-CN"],
    "driftCheckIntervalSec": 300
  },
  "paths": {
    "contract": "contract/schema.yaml",
    "migrations": "migrations",
    "seeds": "seeds",
    "driftPolicy": "drift/policy.yaml"
  },
  "spi": {
    "provider": "default",
    "hooks": []
  }
}
